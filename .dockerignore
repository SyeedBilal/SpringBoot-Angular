# ============================================================
# .dockerignore — shared rules for Angular & Java projects
# Place a copy in each project root (frontend/ and backend/)
# ============================================================

# Version control
.git
.gitignore
.gitattributes

# CI / CD
.github
.gitlab-ci.yml
Jenkinsfile
.circleci

# IDE & editor
.idea
.vscode
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# Docker files themselves (no need to COPY them into the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
README*
CHANGELOG*
LICENSE*
docs/

# ---- Angular-specific ----
node_modules/
dist/
.angular/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Java / Maven-specific ----
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*

# Test reports & coverage
coverage/
.nyc_output/
surefire-reports/

# Environment / secrets (NEVER bake these into images)
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.jks